@{
    Layout = null; // Remove o menu superior nesta tela
}

<!DOCTYPE html>
<html>
<head>
    <title>Login - Biblioteca</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #f4f7f6; height: 100vh; display: flex; align-items: center; justify-content: center; }
        .card-login { width: 400px; border: none; border-radius: 15px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); }
    </style>
</head>
<body>

<div class="card card-login p-4">
    <div class="text-center mb-4">
        <h3>📚 Biblioteca Digital</h3>
        <p class="text-muted">Entre com suas credenciais</p>
    </div>

    <div class="mb-3">
        <label class="form-label">E-mail</label>
        <input type="email" id="email" class="form-control" placeholder="seu@email.com">
    </div>
    <div class="mb-3">
        <label class="form-label">Senha</label>
        <input type="password" id="senha" class="form-control" placeholder="******">
    </div>

    <button class="btn btn-primary w-100 py-2" onclick="fazerLogin()">Entrar</button>
    
    <div id="msgErro" class="alert alert-danger mt-3 d-none"></div>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script>
    function fazerLogin() {
        let dados = {
            email: $('#email').val(),
            senha: $('#senha').val()
        };

        $.post('/Login/Entrar', dados, function (res) {
            if (res.sucesso) {
                window.location.href = '/Home'; // Manda para a Home após logar
            } else {
                $('#msgErro').text(res.mensagem).removeClass('d-none');
            }
        });
    }
</script>

</body>
</html>