<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema Biblioteca</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    
    <style>
        /* TEMA DARK GLOBAL */
        body {
            background-color: #121212 !important;
            color: #e0e0e0 !important;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* NAVBAR AJUSTADA */
        .navbar {
            background-color: #1f1f1f !important;
            border-bottom: 1px solid #333;
        }

        /* Força os links a serem brancos e remove o 'preto' que estava dando erro */
        .navbar-dark .navbar-nav .nav-link {
            color: #ffffff !important;
            font-weight: 500;
            padding: 0.5rem 1rem;
        }

        .navbar-dark .navbar-nav .nav-link:hover {
            color: #3182ce !important; /* Azul destaque no hover */
        }

        .navbar-brand {
            color: #ffffff !important;
            font-size: 1.4rem;
        }

        /* TABELAS E COMPONENTES */
        .table {
            color: #ffffff !important;
            border-color: #333 !important;
        }

        .table-striped tbody tr:nth-of-type(odd) {
            background-color: #1a1a1a !important;
        }

        .modal-content {
            background-color: #1e1e1e !important;
            color: #ffffff !important;
            border: 1px solid #444;
        }

        .form-control, .form-select {
            background-color: #2b2b2b !important;
            border: 1px solid #444 !important;
            color: #ffffff !important;
        }

        .form-control:focus {
            background-color: #333 !important;
            color: #ffffff !important;
            border-color: #3182ce !important;
            box-shadow: none;
        }

        footer {
            border-top: 1px solid #333;
            color: #888;
        }

        /* Badge de Perfil */
        .badge-perfil {
            font-size: 0.75rem;
            vertical-align: middle;
            margin-left: 5px;
        }
    </style>
</head>
<body>
<header>
    <nav class="navbar navbar-expand-sm navbar-dark mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                📚 Biblioteca
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                
                @* MENU PRINCIPAL *@
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Livro" asp-action="Index">Livros</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Emprestimo" asp-action="Index">Empréstimos</a>
                    </li>

                    @* SÓ QUEM É ADMIN VÊ A GESTÃO DE USUÁRIOS *@
                    @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-warning fw-bold" asp-controller="Usuario" asp-action="Index">Usuários</a>
                        </li>
                    }
                </ul>

                @* MENU DE PERFIL E LOGOUT *@
                <ul class="navbar-nav">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            @* Link para Editar Perfil/Minha Conta *@
                            <a class="nav-link text-info" asp-controller="Login" asp-action="MinhaConta" title="Editar meu perfil">
                                Olá, <strong>@User.Identity.Name</strong>
                                <span class="badge @(User.IsInRole("Admin") ? "bg-danger" : "bg-primary") badge-perfil">
                                    @((User.IsInRole("Admin") ? "Admin" : "Leitor"))
                                </span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-danger ms-3" asp-controller="Login" asp-action="Sair">Sair</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Login" asp-action="Index">Entrar</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
</header>

<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="footer py-3 mt-5 text-center">
    <div class="container">
        &copy; 2026 - Sistema de Gestão de Biblioteca - <span class="text-info">Juan Developer</span>
    </div>
</footer>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>